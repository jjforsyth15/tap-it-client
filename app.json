{
  "expo": {
    "name": "tap-it-client",
    "slug": "tap-it-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tapitclient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "org.tapitcard.app",
      "associatedDomains": [
        "applinks:tapitcard.org"
      ],
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TapIt to choose a profile photo from your library."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-secure-store"
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
