# Backend API (no trailing slash). Production default in code: https://tap-it-server.onrender.com
EXPO_PUBLIC_API_BASE_URL=https://tap-it-server.onrender.com

# Local development only (optional):
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
#
# After changing this file: npx expo start -c
#
# Public link-page host for exported URLs (mock until the host is live). No trailing slash.
# EXPO_PUBLIC_LINK_PAGE_BASE_URL=https://tapit.app
#
# Shopping UI (bundles, cart, checkout CTA on /shop). Default: enabled. Set to false to redirect /shop to home.
# EXPO_PUBLIC_ENABLE_SHOP_UI=true
#
# Admin dashboard login (optional). Copy to .env with your values. Restart Metro after edits.
# EXPO_PUBLIC_ADMIN_EMAIL=you@example.com
# EXPO_PUBLIC_ADMIN_PASSWORD=your-secure-password
